{
  "bin": {"llms": "jdeploy-bundle/jdeploy.js"},
  "author": "Yassine Abou",
  "description": "LLMS - AI-powered Kotlin Multiplatform app for text and image generation",
  "main": "index.js",
  "preferGlobal": true,
